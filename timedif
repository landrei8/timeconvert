  --accent3:       #4ec8f0;
  --text:          #eeeef5;
  --muted:         rgba(238,238,245,0.45);
  --bg-from:       #0a0a14;
  --bg-to:         #0f0f1e;
  --radius:        16px;
  --radius-sm:     8px;
  --font-display:  'Syne', sans-serif;
  --font-mono:     'DM Mono', monospace;
}

html { scroll-behavior: smooth; }

body {
  font-family: var(--font-mono);
  background: var(--bg-from);
  color: var(--text);
  min-height: 100vh;
  overflow-x: hidden;
  position: relative;
}

/* ── Animated mesh background ── */
.bg-mesh {
  position: fixed; inset: 0; z-index: 0; pointer-events: none;
  background:
    radial-gradient(ellipse 70% 50% at 15% 20%, rgba(200,240,78,0.07) 0%, transparent 60%),
    radial-gradient(ellipse 50% 60% at 85% 75%, rgba(78,200,240,0.07) 0%, transparent 60%),
