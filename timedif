    linear-gradient(160deg, #0a0a14 0%, #0d0d1c 50%, #0f0f1e 100%);
}
.bg-orb {
  position: fixed; border-radius: 50%; filter: blur(80px); pointer-events: none; z-index: 0;
  animation: orbFloat 12s ease-in-out infinite;
}
.bg-orb-1 { width: 500px; height: 500px; background: rgba(200,240,78,0.055); top: -150px; left: -100px; animation-delay: 0s; }
.bg-orb-2 { width: 400px; height: 400px; background: rgba(78,200,240,0.05); bottom: -100px; right: -80px; animation-delay: -6s; }
.bg-orb-3 { width: 300px; height: 300px; background: rgba(240,78,122,0.04); top: 40%; left: 55%; animation-delay: -3s; }
@keyframes orbFloat {
  0%,100% { transform: translate(0,0) scale(1); }
  33%      { transform: translate(30px,-40px) scale(1.05); }
  66%      { transform: translate(-20px,25px) scale(0.97); }
}

/* ── Grain overlay ── */
body::after {
  content: ''; position: fixed; inset: 0; z-index: 1; pointer-events: none;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
  opacity: 0.4;
}

/* ── Layout ── */
.wrap { position: relative; z-index: 2; max-width: 960px; margin: 0 auto; padding: 0 1.5rem 4rem; }

/* ── Header / Nav ── */
.site-nav {
  display: flex; align-items: center; gap: 1rem;
  padding: 1.4rem 0 1.2rem;
  border-bottom: 1px solid rgba(255,255,255,0.07);
  margin-bottom: 3rem;
}
.nav-logo {
  font-family: var(--font-display); font-weight: 800; font-size: 1rem;
  color: var(--accent); letter-spacing: -0.02em; text-decoration: none;
  line-height: 1.1; margin-right: 0.5rem;
}
.nav-logo span { color: var(--muted); font-weight: 400; font-size: 0.65rem; display: block; letter-spacing: 0.15em; text-transform: uppercase; }
.nav-link {
  font-size: 0.62rem; letter-spacing: 0.12em; text-transform: uppercase;
  color: var(--muted); text-decoration: none; transition: color 0.15s;
  font-family: var(--font-mono);
}
.nav-link:hover { color: var(--text); }
.nav-link.active { color: var(--accent); }
.nav-sep { color: rgba(255,255,255,0.12); font-size: 0.7rem; }
.nav-spacer { flex: 1; }

/* ── Page title ── */
.page-title {
  font-family: var(--font-display); font-weight: 800;
  font-size: clamp(2.2rem, 5vw, 3.4rem);
  line-height: 1.05; letter-spacing: -0.03em;
  margin-bottom: 0.5rem;
}
.page-title em { font-style: normal; color: var(--accent); }
.page-subtitle { font-size: 0.72rem; color: var(--muted); letter-spacing: 0.06em; margin-bottom: 3rem; }

/* ── Glass card ── */
.glass {
  background: var(--glass-bg);
  border: 1px solid var(--glass-border);
  border-radius: var(--radius);
  backdrop-filter: var(--glass-blur);
