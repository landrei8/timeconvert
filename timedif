<script>
// ── Helpers ──────────────────────────────────────────────

function parseDate(str) {
  if (!str) return null;
  const [y,m,d] = str.split('-').map(Number);
  return new Date(y, m-1, d);
}

function toISO(d) {
  const pad = n => String(n).padStart(2,'0');
  return d.getFullYear() + '-' + pad(d.getMonth()+1) + '-' + pad(d.getDate());
}

function dayName(d) {
  return ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'][d.getDay()];
}

function monthName(d) {
  return ['January','February','March','April','May','June','July',
          'August','September','October','November','December'][d.getMonth()];
}

function formatFull(d) {
  return dayName(d) + ', ' + d.getDate() + ' ' + monthName(d) + ' ' + d.getFullYear();
}

function isWeekend(d) { return d.getDay() === 0 || d.getDay() === 6; }
function isWeekday(d) { return !isWeekend(d); }

function diffCalendar(a, b) {
  return Math.round((b - a) / 86400000);
}

function countBetween(a, b, predicate, includeEnd) {
  let count = 0, cur = new Date(a);
  const end = new Date(b);
  while (cur <= end) {
    if (includeEnd || cur < end) {
      if (predicate(cur)) count++;
    }
    cur.setDate(cur.getDate() + 1);
  }
  return count;
}

function addWorkdays(start, n, direction) {
  let cur = new Date(start);
  let remaining = Math.abs(n);
  const step = direction === 'sub' ? -1 : 1;
  while (remaining > 0) {
    cur.setDate(cur.getDate() + step);
    if (isWeekday(cur)) remaining--;
  }
  return cur;
}

function addCalendarDays(start, n, direction) {
  const d = new Date(start);
  d.setDate(d.getDate() + (direction === 'sub' ? -n : n));
  return d;
}

function chip(val, lbl) {
  return `<div class="result-chip">
    <div class="result-chip-val">${val}</div>
    <div class="result-chip-lbl">${lbl}</div>
  </div>`;
}

function tag(text, cls) {
  return `<span class="result-tag ${cls||''}">${text}</span>`;
}

// ── Toggle pill logic ──────────────────────────────────

document.querySelectorAll('.toggle-pill').forEach(pill => {
  const cb = pill.querySelector('input[type=checkbox]');
  function sync() {
    pill.classList.toggle('checked', cb.checked);
  }
  sync();
  pill.addEventListener('click', () => { cb.checked = !cb.checked; sync(); });
});

// ── Tabs ──────────────────────────────────────────────

document.querySelectorAll('.tab-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
    document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('panel-' + btn.dataset.tab).classList.add('active');
  });
});

// ── Default dates (today & today+7) ──────────────────────

const today = new Date();
const week  = new Date(today); week.setDate(today.getDate() + 7);
const todayISO = toISO(today);
const weekISO  = toISO(week);

['diff-start','wd-start','as-start'].forEach(id => {
  document.getElementById(id).value = todayISO;
});
['diff-end','wd-end'].forEach(id => {
  document.getElementById(id).value = weekISO;
});
document.getElementById('as-days').value = 7;

// ── TAB 1 — Date Difference ───────────────────────────

document.getElementById('diff-calc').addEventListener('click', () => {
  const start = parseDate(document.getElementById('diff-start').value);
  const end   = parseDate(document.getElementById('diff-end').value);
  const errEl = document.getElementById('diff-error');
  const res   = document.getElementById('diff-result');

  errEl.classList.remove('visible');
  if (!start || !end || end < start) { errEl.classList.add('visible'); res.classList.remove('visible'); return; }

  const inclEnd    = document.getElementById('diff-inclend').checked;
  const skipWknd   = document.getElementById('diff-skipweekend').checked;
  const onlyWknd   = document.getElementById('diff-inclweekend').checked;

  const totalDays  = diffCalendar(start, end) + (inclEnd ? 1 : 0);
  const workdays   = countBetween(start, end, isWeekday, inclEnd);
  const weekends   = countBetween(start, end, isWeekend, inclEnd);

  let primary, primaryLabel;
  if (skipWknd) {
    primary = workdays; primaryLabel = 'workdays (Mon–Fri)';
  } else if (onlyWknd) {
    primary = weekends; primaryLabel = 'weekend days (Sat–Sun)';
  } else {
    primary = totalDays; primaryLabel = 'total days';
  }

  const weeks  = Math.floor(totalDays / 7);
  const days   = totalDays % 7;
  const months = (end.getFullYear() - start.getFullYear()) * 12 + (end.getMonth() - start.getMonth());

  document.getElementById('diff-primary').innerHTML = primary + '<small>' + (primary === 1 ? 'day' : 'days') + '</small>';
  document.getElementById('diff-primary-label').textContent = primaryLabel;

  document.getElementById('diff-chips').innerHTML =
    chip(totalDays, 'Calendar Days') +
    chip(workdays,  'Workdays') +
    chip(weekends,  'Weekends') +
    chip(weeks + 'w ' + days + 'd', 'Weeks & Days');

  document.getElementById('diff-breakdown').innerHTML =
    tag('From: ' + formatFull(start)) +
    tag('To: ' + formatFull(end)) +
    tag(months + ' months', 'blue') +
    tag(Math.floor(totalDays / 365.25).toFixed(1) + ' years approx', 'blue') +
    (inclEnd ? tag('End day included', 'highlight') : tag('End day excluded'));

  res.classList.add('visible');
});

// ── TAB 2 — Add / Subtract ────────────────────────────

document.getElementById('as-calc').addEventListener('click', () => {
  const start     = parseDate(document.getElementById('as-start').value);
  const days      = parseInt(document.getElementById('as-days').value);
  const op        = document.getElementById('as-op').value;
  const workOnly  = document.getElementById('as-workonly').checked;
  const errEl     = document.getElementById('as-error');
  const res       = document.getElementById('as-result');

  errEl.classList.remove('visible');
  if (!start || isNaN(days) || days < 0) { errEl.classList.add('visible'); res.classList.remove('visible'); return; }

  const result = workOnly ? addWorkdays(start, days, op) : addCalendarDays(start, days, op);

  document.getElementById('as-primary').innerHTML =
    result.getDate() + ' <small>' + monthName(result) + ' ' + result.getFullYear() + '</small>';
  document.getElementById('as-label').textContent = 'resulting date';

  const calDiff = Math.abs(diffCalendar(start, result));
  const wdCount = workOnly ? days : countBetween(
    op === 'sub' ? result : start,
    op === 'sub' ? start  : result,
    isWeekday, true
  );

  document.getElementById('as-chips').innerHTML =
    chip(formatFull(result).split(', ')[0], 'Weekday') +
    chip(calDiff, 'Calendar Days') +
    chip(wdCount, 'Workdays');

  document.getElementById('as-breakdown').innerHTML =
    tag((op === 'add' ? '+ ' : '− ') + days + (workOnly ? ' workdays' : ' calendar days'), 'highlight') +
    tag('From: ' + formatFull(start)) +
    tag('Lands on: ' + dayName(result), isWeekend(result) ? 'pink' : 'highlight');

  res.classList.add('visible');
});

// ── TAB 3 — Workday Counter ───────────────────────────

document.getElementById('wd-calc').addEventListener('click', () => {
  const start   = parseDate(document.getElementById('wd-start').value);
  const end     = parseDate(document.getElementById('wd-end').value);
  const inclEnd = document.getElementById('wd-incl').checked;
  const errEl   = document.getElementById('wd-error');
  const res     = document.getElementById('wd-result');

  errEl.classList.remove('visible');
  if (!start || !end || end < start) { errEl.classList.add('visible'); res.classList.remove('visible'); return; }

  const total    = diffCalendar(start, end) + (inclEnd ? 1 : 0);
  const workdays = countBetween(start, end, isWeekday, inclEnd);
  const wknds    = countBetween(start, end, isWeekend, inclEnd);

  document.getElementById('wd-primary').innerHTML =
    workdays + '<small>' + (workdays === 1 ? 'day' : 'days') + '</small>';

  document.getElementById('wd-chips').innerHTML =
    chip(total, 'Total Days') +
    chip(workdays, 'Workdays') +
    chip(wknds, 'Weekend Days') +
    chip(Math.round(workdays / total * 100) + '%', 'Workday Ratio');

  // Build mini calendar strip for first 2 weeks
  const strip   = document.getElementById('wd-strip');
  strip.innerHTML = '';
  const maxShow = Math.min(total, 28);
  for (let i = 0; i < maxShow; i++) {
    const d = new Date(start); d.setDate(d.getDate() + i);
    const badge = document.createElement('div');
    badge.className = 'wd-badge ' + (isWeekend(d) ? 'weekend' : 'work');
    badge.title = formatFull(d);
    badge.textContent = dayName(d)[0];
    strip.appendChild(badge);
  }
  if (total > 28) {
    const more = document.createElement('span');
    more.style.cssText = 'font-size:0.58rem;color:var(--muted);align-self:center;font-family:var(--font-mono)';
    more.textContent = '+' + (total - 28) + ' more';
    strip.appendChild(more);
  }

  res.classList.add('visible');
});

// ── Auto-calculate on date change ─────────────────────
['diff-start','diff-end','diff-inclend','diff-skipweekend','diff-inclweekend'].forEach(id => {
  document.getElementById(id).addEventListener('change', () => {
    if (document.getElementById('diff-result').classList.contains('visible'))
      document.getElementById('diff-calc').click();
  });
});
['wd-start','wd-end','wd-incl'].forEach(id => {
  document.getElementById(id).addEventListener('change', () => {
    if (document.getElementById('wd-result').classList.contains('visible'))
      document.getElementById('wd-calc').click();
  });
});
</script>
</body>
</html>
